              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"storeId\": 5,\n  \"rating\": 4\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/users/ratings",
              "host": [
                "{{baseUrl}}"
              ],
