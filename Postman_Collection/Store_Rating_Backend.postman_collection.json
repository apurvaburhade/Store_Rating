            }
          }
        }
      ]
    },
    {
      "name": "Normal User",
      "description": "Normal user routes for browsing stores and managing ratings.",
      "item": [
        {
          "name": "List Stores",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/users/stores?sortBy=name&order=ASC&search=",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "users",
                "stores"
              ],
              "query": [
                {
                  "key": "sortBy",
                  "value": "name"
                },
                {
                  "key": "order",
                  "value": "ASC"
                },
                {
                  "key": "search",
                  "value": ""
                }
              ]
            }
          }
        },
